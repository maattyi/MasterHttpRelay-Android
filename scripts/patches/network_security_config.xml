<?xml version="1.0" encoding="utf-8"?>
<!--
  VelumVPN Network Security Config — production-safe baseline.

  Post-refactor design:
    * Trust anchors are SYSTEM ONLY. We never opt into user-installed CAs,
      because the app no longer performs MITM and therefore has no need
      for one. This removes a long-standing attack surface (a malicious
      app or shipped enterprise profile cannot trick Velum into
      validating an attacker-controlled chain just because the user
      installed it).
    * Cleartext is allowed because the local HTTP proxy listener and
      the plain-HTTP relay path serve plaintext on 127.0.0.1. Note:
      this does NOT permit cleartext to arbitrary remote hosts — Velum
      contacts script.google.com over HTTPS only, enforced in code by
      SecureHttpClient (TLS 1.2/1.3 + pinning).
    * Debug overrides are also system-only. There is intentionally no
      "trust user CAs in debug" backdoor — once shipped, this app
      validates against the platform store everywhere.
-->
<network-security-config>

    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
      script.google.com / script.googleusercontent.com:
      forbid cleartext outright + system trust only. The actual public-key
      pinning is enforced in code via OkHttp CertificatePinner so that
      pin rotation does not require an APK update.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">script.google.com</domain>
        <domain includeSubdomains="true">script.googleusercontent.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

</network-security-config>
